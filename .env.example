# ─────────────────────────────────────────────
# LandVerify — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
NODE_ENV=development
APP_NAME=LandVerify
APP_VERSION=0.1.0

# ── Frontend (Next.js) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Backend (FastAPI) ─────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_SECRET_KEY=change-me-to-a-64-char-random-string
API_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (PostgreSQL via Supabase) ────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/landverify
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis (chat pub/sub + caching) ────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── KYC — Smile ID ────────────────────────────
SMILE_ID_PARTNER_ID=your-partner-id
SMILE_ID_API_KEY=your-api-key
SMILE_ID_ENVIRONMENT=sandbox

# ── Payments — Paystack ───────────────────────
PAYSTACK_SECRET_KEY=sk_test_your-key
PAYSTACK_PUBLIC_KEY=pk_test_your-key

# ── Storage — Supabase Storage ────────────────
STORAGE_BUCKET_DOCUMENTS=landverify-documents
STORAGE_BUCKET_AVATARS=landverify-avatars

# ── Email — Resend ────────────────────────────
RESEND_API_KEY=re_your-key
EMAIL_FROM=noreply@landverify.ng

# ── Cloudflare ────────────────────────────────
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-token

# ── Monitoring — Sentry ───────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/project
